# TelemetryDeck API credentials
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요:
#   cp .env.example .env
#   vi .env
TELEMETRYDECK_EMAIL=
TELEMETRYDECK_PASSWORD=
TELEMETRYDECK_APP_ID=

# Supabase credentials
# service_role key는 RLS 우회 → 스크립트 전용, 절대 앱 코드에 포함 금지
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
