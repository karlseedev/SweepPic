    "permissions.denied.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SweepPic needs full access to your\nphoto library to work properly.\nPlease select \"Allow Full Access\" in Settings."
