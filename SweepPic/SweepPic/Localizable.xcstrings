    "coachMark.c2.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "Tap the + button\nto open Face Comparison\nSwipe left/right to see other people" }
        },
        "ko" : {
          "stringUnit" : { "state" : "translated", "value" : "+버튼을 눌러 얼굴비교화면으로 이동하세요\u2028인물이 여러 명이면 좌우로 넘겨볼 수 있어요" }
        }
      }
    },
    "coachMark.c2.notice" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "\nNote: Faces may not be detected\nor misclassified depending on\nangle or resolution" }
        },
        "ko" : {
          "stringUnit" : { "state" : "translated", "value" : "\n※ 얼굴은 각도, 해상도에 따라 검출되지 않거나\u2028다른 인물로 분류될 수 있습니다" }
        }
      }
