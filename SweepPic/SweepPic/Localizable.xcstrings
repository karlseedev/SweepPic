    "coachMark.c3.step1.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "Select the faces you don't like\nSwipe to check other people\nand remove their photos too" }
        },
        "ko" : {
          "stringUnit" : { "state" : "translated", "value" : "마음에 들지 않는 얼굴을 선택하세요\n옆으로 이동해서 다른 인물의 얼굴도\u2028확인하고 삭제할 수 있어요" }
        }
      }
    },
    "coachMark.c3.step1.keyword" : {
