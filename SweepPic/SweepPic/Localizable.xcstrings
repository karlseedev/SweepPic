          "stringUnit" : { "state" : "translated", "value" : "Deleted photos from your library\nare temporarily stored in Trash" }
        },
        "ko" : {
          "stringUnit" : { "state" : "translated", "value" : "보관함에서 삭제된 사진은\n삭제대기함에 임시 보관돼요" }
        }
      }
    },
    "coachMark.e2.step2.keyword" : {
