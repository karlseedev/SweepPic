    "coachMark.c1.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "Photos with a white border support\nFace Comparison — compare faces\nacross photos and choose\nwhich to remove" }
        },
        "ko" : {
          "stringUnit" : { "state" : "translated", "value" : "하얀색 테두리가 표시된 사진은\n여러 사진의 얼굴을 비교해서 삭제하는\n인물사진 비교정리가 가능한 사진이에요" }
        }
      }
    },
