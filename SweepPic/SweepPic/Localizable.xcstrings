      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : { "state" : "translated", "value" : "The deleted photo has been\nmoved to Trash\nWant to check it in Trash?" }
        },
        "ko" : {
          "stringUnit" : { "state" : "translated", "value" : "방금 삭제된 사진은\u2028삭제대기함으로 이동됐어요\n삭제대기함에서 확인해볼까요?" }
        }
      }
